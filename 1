-- ================ REFRESH ================
local isRefreshing = false
local function refresh()
    if isRefreshing then return end
    isRefreshing = true
    refreshBtn.Text = "..."
    refreshBtn.BackgroundColor3 = Color3.fromRGB(100,100,110)

    for _, c in ipairs(scroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    allRows = {}

    local fruits = getFruitsFromBackpack()
    local total = #fruits
    footer.Text = string.format("Scanning 0/%d...", total)

    if total == 0 then
        footer.Text = "No harvested fruits found."
        refreshBtn.Text = "🔄"
        refreshBtn.BackgroundColor3 = Color3.fromRGB(70,130,200)
        isRefreshing = false
        lastFruits = {}
        return
    end

    local done = 0
    for _, fruit in ipairs(fruits) do
        task.spawn(function() fetchValue(fruit); done = done + 1 end)
        task.wait(0.04)
    end

    local startT = tick()
    while done < total and tick() - startT < 30 do
        footer.Text = string.format("Scanning %d/%d...", done, total)
        task.wait(0.15)
    end

    table.sort(fruits, function(a,b) return a.value > b.value end)
    lastFruits = fruits

    local sum, favs = 0, 0
    for i, fruit in ipairs(fruits) do
        buildRow(fruit, i)
        sum = sum + fruit.value
        if fruit.favorited then favs = favs + 1 end
    end

    footer.Text = string.format("TOTAL: %d  (%d ⭐)  |  %s",
        total, favs, NumberUtils.Abbreviate(sum))

    refreshBtn.Text = "🔄"
    refreshBtn.BackgroundColor3 = Color3.fromRGB(70,130,200)
    isRefreshing = false
end

