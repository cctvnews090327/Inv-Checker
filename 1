-- ================ AUTO-FAVORITE WIRING ================
local isFavoriting = false

local function doFavOp(mode, needsThreshold, label, btn, origColor)
    if isFavoriting then return end
    if #lastFruits == 0 then
        favStatus.Text = "Refresh inventory first."
        return
    end
    local thresh = 0
    if needsThreshold then
        thresh = parseValue(favThreshBox.Text)
        if thresh <= 0 then
            favStatus.Text = "Enter a threshold (e.g. 10m)."
            return
        end
        AF.threshold = thresh
    end
    isFavoriting = true
    local origText = btn.Text
    btn.Text = "..."
    btn.BackgroundColor3 = Color3.fromRGB(100,100,110)
    local myGen = STOP.gen

    task.spawn(function()
        local changed, scanned, unknown = runFavoriteOp(lastFruits, thresh, mode, myGen)
        if not isStale(myGen) then
            favStatus.Text = string.format("[%s] %d changed  (scanned %d, %d unknown)",
                label, changed, scanned, unknown)
        else
            favStatus.Text = string.format("[%s] cancelled (%d done)", label, changed)
        end
        btn.Text = origText
        btn.BackgroundColor3 = origColor
        isFavoriting = false
        if not isStale(myGen) then task.wait(0.2); refresh() end
    end)
end

