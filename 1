        row.BackgroundColor3 = ok and Color3.fromRGB(80,180,100) or Color3.fromRGB(180,80,80)
        task.wait(0.25)
        row.BackgroundColor3 = baseColor
        clicking = false
    end)

    table.insert(allRows, {row=row, fruit=fruit, index=index})
end

