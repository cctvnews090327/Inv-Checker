-- AUTO-COLLECT DROPPED FRUIT (merged from v4 debug)
-- ============================================================

local AC = {
    enabled    = false,
    alive      = true,
    collected  = {},
    failCount  = {},
    stats      = { total = 0, scans = 0, fires = 0, skips = 0 },
    homeCFrame = nil,
    addedConn  = nil,
    removedConn= nil,
    -- tunables
    SCAN_RATE    = 2.0,
    PER_ITEM_GAP = 0.35,
    TP_SETTLE    = 0.12,
    VERIFY_WAIT  = 1.2,
    MAX_RETRIES  = 2,
    HOVER_OFFSET = 3,
}

-- kill any previous instance
if _G.__AutoCollectFruit_Stop then pcall(_G.__AutoCollectFruit_Stop) end
_G.__AutoCollectFruit_Stop = function() AC.alive = false; AC.enabled = false end

local function ac_log(...) print("[AC]", ...) end

local function ac_getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function ac_getModelPos(model)
    if model.PrimaryPart then return model.PrimaryPart.Position end
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("BasePart") then return d.Position end
    end
    local ok, cf = pcall(function() return model:GetPivot() end)
    if ok then return cf.Position end
end

local function ac_findPrompt(model)
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("ProximityPrompt") then return d end
    end
end

local function ac_describeFolder()
    local f = Workspace:FindFirstChild("DroppedItems")
    if not f then return "no folder" end
    local total, fruits, pending, done = 0, 0, 0, 0
    for _, m in ipairs(f:GetChildren()) do
        total += 1
        if m:GetAttribute("ItemCategory") == "HarvestedFruits" then
            fruits += 1
            if AC.collected[m] then done += 1 else pending += 1 end
        end
    end
    return string.format("folder=%d fruits=%d pending=%d done=%d", total, fruits, pending, done)
end

local function ac_collect(model)
    if not AC.alive or not AC.enabled then return end
    if AC.collected[model] then AC.stats.skips += 1; return end
    if not model.Parent then return end
    if model:GetAttribute("ItemCategory") ~= "HarvestedFruits" then return end

    local prompt = ac_findPrompt(model)
    if not prompt then return end
    local fruitPos = ac_getModelPos(model)
    if not fruitPos then return end
    local hrp = ac_getHRP()
    if not hrp then return end

    local savedHere = false
    if not AC.homeCFrame then
        AC.homeCFrame = hrp.CFrame
        savedHere = true
    end

    pcall(function()
        hrp.CFrame = CFrame.new(fruitPos + Vector3.new(0, AC.HOVER_OFFSET, 0))
    end)
    task.wait(AC.TP_SETTLE)

    pcall(function()
        prompt.MaxActivationDistance = 1000
        prompt.RequiresLineOfSight   = false
        prompt.HoldDuration          = 0
        prompt.Enabled               = true
    end)

    pcall(function() fireproximityprompt(prompt) end)
    AC.stats.fires += 1

    task.wait(AC.VERIFY_WAIT)

    if not model.Parent then
        AC.collected[model] = true
        AC.failCount[model] = nil
    else
        AC.failCount[model] = (AC.failCount[model] or 0) + 1
        if AC.failCount[model] >= AC.MAX_RETRIES then
            AC.collected[model] = true
        end
    end

    if savedHere then
        local h = ac_getHRP()
        if h and AC.homeCFrame then pcall(function() h.CFrame = AC.homeCFrame end) end
        AC.homeCFrame = nil
    end

    task.wait(AC.PER_ITEM_GAP)
end

local function ac_scanAll()
    AC.stats.scans += 1
    local folder = Workspace:FindFirstChild("DroppedItems")
    if not folder then return end

    AC.homeCFrame = nil
    for _, m in ipairs(folder:GetChildren()) do
        if not AC.alive or not AC.enabled then break end
        if not AC.collected[m] and m:GetAttribute("ItemCategory") == "HarvestedFruits" then
            ac_collect(m)
        end
    end

    if AC.homeCFrame then
        local h = ac_getHRP()
        if h then pcall(function() h.CFrame = AC.homeCFrame end) end
        AC.homeCFrame = nil
    end
end

local function ac_start()
    local folder = Workspace:WaitForChild("DroppedItems", 10)
    if not folder then warn("[AC] DroppedItems missing"); return end

    if AC.addedConn   then AC.addedConn:Disconnect()   end
    if AC.removedConn then AC.removedConn:Disconnect() end

    AC.addedConn = folder.ChildAdded:Connect(function(m)
        task.wait(0.2)
        ac_collect(m)
    end)
    AC.removedConn = folder.ChildRemoved:Connect(function(m)
        if not AC.collected[m] then
            AC.stats.total += 1
        end
        AC.collected[m] = nil
        AC.failCount[m] = nil
    end)

    ac_log("STARTED.", ac_describeFolder())
    ac_scanAll()
end

local function ac_stop()
    if AC.addedConn   then AC.addedConn:Disconnect();   AC.addedConn   = nil end
    if AC.removedConn then AC.removedConn:Disconnect(); AC.removedConn = nil end
    table.clear(AC.collected)
    table.clear(AC.failCount)
    ac_log("STOPPED")
end

-- background scan loop
task.spawn(function()
    while AC.alive do
        task.wait(AC.SCAN_RATE)
        if AC.enabled then ac_scanAll() end
    end
end)

