-- ============ ROWS ============

local mutationColors = {
    Electric = Color3.fromRGB(255,230,80), Gold = Color3.fromRGB(240,200,60),
    Rainbow = Color3.fromRGB(255,130,220), Frozen = Color3.fromRGB(120,200,255),
    Wet = Color3.fromRGB(90,160,220), Burnt = Color3.fromRGB(180,90,60),
    Shocked = Color3.fromRGB(220,220,100), Chilled = Color3.fromRGB(160,220,240),
    Bloodlit = Color3.fromRGB(200,60,60), Moonlit = Color3.fromRGB(180,180,240),
    Starstruck = Color3.fromRGB(255,200,100),
}

local allRows = {}
local lastFruits = {}

local function rowBaseColor(i)
    return i % 2 == 0 and Color3.fromRGB(30,33,40) or Color3.fromRGB(36,39,46)
end

local function buildRow(fruit, index)
    local row = Instance.new("TextButton")
    row.Size = UDim2.new(1, -4, 0, 30)
    row.BackgroundColor3 = rowBaseColor(index)
    row.BorderSizePixel = 0
    row.Text = ""
    row.AutoButtonColor = false
    row.LayoutOrder = index
    row.Parent = scroll
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)

    local function cell(text, xScale, widthScale, color)
        local l = Instance.new("TextLabel")
        l.BackgroundTransparency = 1
        l.Position = UDim2.new(xScale, 10, 0, 0)
        l.Size = UDim2.new(widthScale, -10, 1, 0)
        l.Text = text
        l.TextColor3 = color or Color3.fromRGB(225,225,230)
        l.Font = Enum.Font.Gotham
        l.TextSize = 12
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.TextTruncate = Enum.TextTruncate.AtEnd
        l.Parent = row
        return l
    end

    cell(tostring(index)..".", 0, 0.06, Color3.fromRGB(150,155,165))
    cell(fruit.name, 0.06, 0.34)
    cell(string.format("%.2fkg", fruit.weight), 0.40, 0.16)
    cell(fruit.mutation, 0.56, 0.22, mutationColors[fruit.mutation])
    cell(NumberUtils.Abbreviate(fruit.value), 0.78, 0.22, Color3.fromRGB(120,220,140))

    local baseColor = rowBaseColor(index)
    row.MouseEnter:Connect(function() row.BackgroundColor3 = Color3.fromRGB(55,90,140) end)
    row.MouseLeave:Connect(function() row.BackgroundColor3 = baseColor end)

    local clicking = false
    row.MouseButton1Click:Connect(function()
        if clicking then return end
        clicking = true
        row.BackgroundColor3 = Color3.fromRGB(200,160,60)
        local ok = equipFruit(fruit)
        row.BackgroundColor3 = ok and Color3.fromRGB(80,180,100) or Color3.fromRGB(180,80,80)
        task.wait(0.25)
        row.BackgroundColor3 = baseColor
        clicking = false
    end)

    table.insert(allRows, {row = row, fruit = fruit, index = index})
end

searchBox:GetPropertyChangedSignal("Text"):Connect(function()
    local q = searchBox.Text:lower()
    for _, entry in ipairs(allRows) do
        local hay = (entry.fruit.name .. " " .. entry.fruit.mutation):lower()
        entry.row.Visible = (q == "" or hay:find(q, 1, true) ~= nil)
    end
end)

-- ============ REFRESH ============

local isRefreshing = false

local function refresh()
    if isRefreshing then return end
    isRefreshing = true
    refreshBtn.Text = "Loading..."
    refreshBtn.BackgroundColor3 = Color3.fromRGB(100,100,110)

    for _, c in ipairs(scroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    allRows = {}

    local fruits = getFruitsFromBackpack()
    local total = #fruits
    footer.Text = string.format("Scanning 0/%d...", total)

    if total == 0 then
        footer.Text = "No harvested fruits found."
        refreshBtn.Text = "🔄 Refresh"
        refreshBtn.BackgroundColor3 = Color3.fromRGB(70,130,200)
        isRefreshing = false
        lastFruits = {}
        return
    end

    local done = 0
    for _, fruit in ipairs(fruits) do
        task.spawn(function() fetchValue(fruit); done = done + 1 end)
        task.wait(0.04)
    end

    local startT = tick()
    while done < total and tick() - startT < 30 do
        footer.Text = string.format("Scanning %d/%d...", done, total)
        task.wait(0.15)
    end

    table.sort(fruits, function(a,b) return a.value > b.value end)
    lastFruits = fruits

    local sum = 0
    for i, fruit in ipairs(fruits) do
        buildRow(fruit, i)
        sum = sum + fruit.value
    end

    footer.Text = string.format("TOTAL: %d fruits  |  Value: %s",
        total, NumberUtils.Abbreviate(sum))

    refreshBtn.Text = "🔄 Refresh"
    refreshBtn.BackgroundColor3 = Color3.fromRGB(70,130,200)
    isRefreshing = false
end

refreshBtn.MouseButton1Click:Connect(refresh)

-- ============ AUTO DROP ============

local isDropping = false
dropBtn.MouseButton1Click:Connect(function()
    if isDropping then return end
    if #lastFruits == 0 then
        dropStatus.Text = "Refresh inventory first."
        return
    end

    local target = parseValue(targetBox.Text)
    if target <= 0 then
        dropStatus.Text = "Invalid target."
        return
    end

    local perDrop = tonumber(delayBox.Text) or 1.0
    if perDrop < 0.3 then perDrop = 0.3 end

    isDropping = true
    dropBtn.Text = "PLANNING..."
    dropBtn.BackgroundColor3 = Color3.fromRGB(100,100,110)

    local picked, total = selectFruitsForTarget(lastFruits, target)
    if #picked == 0 then
        dropStatus.Text = "No droppable fruits."
        dropBtn.Text = "DROP"
        dropBtn.BackgroundColor3 = Color3.fromRGB(80,160,90)
        isDropping = false
        return
    end

    dropStatus.Text = string.format("Plan: %d fruits = %s (target %s)",
        #picked, NumberUtils.Abbreviate(total), NumberUtils.Abbreviate(target))
    dropBtn.Text = "DROPPING..."

    task.spawn(function()
        local dropped, droppedValue = 0, 0
        for _, f in ipairs(picked) do
            local floorN = countFloorFruits()
            if floorN >= FLOOR_LIMIT then
                dropStatus.Text = string.format("Floor full (%d/%d). Waiting for pickup...",
                    floorN, FLOOR_LIMIT)
                local ok2 = waitForFloorSpace(function(n)
                    dropStatus.Text = string.format("Floor full (%d/%d). Waiting...  [%d/%d done]",
                        n, FLOOR_LIMIT, dropped, #picked)
                end, 120)
                if not ok2 then
                    dropStatus.Text = string.format("Timed out waiting for floor space. Stopped at %d/%d.",
                        dropped, #picked)
                    break
                end
            end

            local ok = dropFruit(f)
            if ok then
                dropped = dropped + 1
                droppedValue = droppedValue + f.value
                dropStatus.Text = string.format("Dropped %d/%d (%s / %s)  Floor:%d/%d",
                    dropped, #picked,
                    NumberUtils.Abbreviate(droppedValue),
                    NumberUtils.Abbreviate(target),
                    countFloorFruits(), FLOOR_LIMIT)
            end
            task.wait(perDrop)
        end
        dropStatus.Text = string.format("Done! %d/%d = %s (target %s)",
            dropped, #picked,
            NumberUtils.Abbreviate(droppedValue),
            NumberUtils.Abbreviate(target))
        dropBtn.Text = "DROP"
        dropBtn.BackgroundColor3 = Color3.fromRGB(80,160,90)
        isDropping = false
        task.wait(1)
        refresh()
    end)
end)

-- ============ COPY ============

copyBtn.MouseButton1Click:Connect(function()
    if #allRows == 0 then
        copyBtn.Text = "Empty!"
        task.wait(1); copyBtn.Text = "📋 Copy"; return
    end
    local lines = {}
    table.insert(lines, string.format("%-4s %-25s %-10s %-12s %s","#","NAME","WEIGHT","MUTATION","VALUE"))
    table.insert(lines, string.rep("-", 65))
    local total = 0
    for i, entry in ipairs(allRows) do
        local f = entry.fruit
        table.insert(lines, string.format("%-4s %-25s %-10s %-12s %s",
            tostring(i)..".", f.name, string.format("%.2fkg", f.weight),
            f.mutation, NumberUtils.Abbreviate(f.value)))
        total = total + f.value
    end
    table.insert(lines, string.rep("-", 65))
    table.insert(lines, string.format("TOTAL: %d fruits  |  Value: %s",
        #allRows, NumberUtils.Abbreviate(total)))
    local output = table.concat(lines, "\n")
    local copied = false
    pcall(function() if setclipboard then setclipboard(output); copied = true end end)
    pcall(function() if toclipboard and not copied then toclipboard(output); copied = true end end)
    pcall(function() if writefile then writefile("fruit-inventory-"..LocalPlayer.Name..".txt", output) end end)
    copyBtn.Text = copied and "✓ Copied!" or "Saved file"
    copyBtn.BackgroundColor3 = Color3.fromRGB(80,180,100)
    task.wait(1.2)
    copyBtn.Text = "📋 Copy"
    copyBtn.BackgroundColor3 = Color3.fromRGB(120,90,200)
end)

refresh()
