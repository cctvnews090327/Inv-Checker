    refresh()
end)

-- ================ DROP RUNNER ================
local isDropping = false

local function runDrop(picked, plannedTotal, label)
    if #picked == 0 then
        dropStatus.Text = "No droppable fruits (favorites are skipped)."
        return
    end

    local perDrop = tonumber(delayBox.Text) or 1.5
    if perDrop < 0.3 then perDrop = 0.3 end

    isDropping = true
    dropBtn.Text   = "..."
    dropNBtn.Text  = "..."
    dropBtn.BackgroundColor3  = Color3.fromRGB(100,100,110)
    dropNBtn.BackgroundColor3 = Color3.fromRGB(100,100,110)

    local dirLabel = (DIR.value == "asc") and "↑" or "↓"
    dropStatus.Text = string.format("[%s %s] Plan: %d fruits = %s",
        label, dirLabel, #picked, NumberUtils.Abbreviate(plannedTotal))

    local myGen = STOP.gen

    task.spawn(function()
        local dropped, droppedValue, failed = 0, 0, 0
        for _, f in ipairs(picked) do
            if isStale(myGen) then
                dropStatus.Text = string.format("Cancelled at %d/%d.", dropped, #picked)
                break
            end
            -- defensive: skip if got favorited mid-run
            if f.favorited or (f.tool and f.tool.Parent and isFavorited(f.tool)) then
                f.favorited = true
            else
                local floorN = countFloorFruits()
                if floorN >= FLOOR_LIMIT then
                    dropStatus.Text = "Floor full. Waiting..."
                    local ok2 = waitForFloorSpace(function(n)
                        if isStale(myGen) then return end
                        dropStatus.Text = string.format("Floor %d/%d. Waiting...  [%d/%d]",
                            n, FLOOR_LIMIT, dropped, #picked)
                    end, 120)
                    if isStale(myGen) then
                        dropStatus.Text = string.format("Cancelled at %d/%d.", dropped, #picked)
                        break
                    end
                    if not ok2 then
                        dropStatus.Text = string.format("Timeout at %d/%d.", dropped, #picked)
                        break
                    end
                end

                if isStale(myGen) then break end
                local ok = dropFruit(f)
                if isStale(myGen) then
                    dropStatus.Text = string.format("Cancelled at %d/%d.", dropped, #picked)
                    break
                end
                if ok then
                    dropped = dropped + 1
                    droppedValue = droppedValue + (f.value or 0)
                    dropStatus.Text = string.format("[%s %s] %d/%d  (%s)  Floor:%d/%d",
                        label, dirLabel, dropped, #picked,
                        NumberUtils.Abbreviate(droppedValue),
                        countFloorFruits(), FLOOR_LIMIT)
                else
                    failed = failed + 1
                    dropStatus.Text = string.format("Throttled - %s  [%d ok / %d fail]",
                        f.name, dropped, failed)
                    task.wait(1.0)
                end
                task.wait(perDrop)
            end
        end
        if not isStale(myGen) then
            dropStatus.Text = string.format("Done! %d ok, %d failed = %s",
                dropped, failed, NumberUtils.Abbreviate(droppedValue))
        end

        dropBtn.Text  = "DROP $"
        dropNBtn.Text = "DROP N"
        dropBtn.BackgroundColor3  = Color3.fromRGB(80,160,90)
        dropNBtn.BackgroundColor3 = Color3.fromRGB(200,140,60)
        isDropping = false
        if not isStale(myGen) then task.wait(1); refresh() end
    end)
end

