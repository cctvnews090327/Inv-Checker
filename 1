-- =================== DATA ===================

local function getFruitsFromBackpack()
    local fruits = {}
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local character = LocalPlayer.Character
    local containers = {}
    if backpack then table.insert(containers, backpack) end
    if character then table.insert(containers, character) end

    for _, container in ipairs(containers) do
        for _, item in ipairs(container:GetChildren()) do
            local fruitName = item:GetAttribute("FruitName")
            local fruitId   = item:GetAttribute("Id")
            local harvested = item:GetAttribute("HarvestedFruit")
            if fruitName and fruitId and harvested then
                table.insert(fruits, {
                    tool = item, name = fruitName, id = fruitId,
                    mutation = item:GetAttribute("Mutation") or "None",
                    weight = item:GetAttribute("Weight") or 0,
                    isProxy = item:GetAttribute("FruitProxy") == true,
                    value = 0,
                })
            end
        end
    end
    return fruits
end

local function fetchValue(fruit)
    local ok, response = pcall(function()
        return Networking.NPCS.GetFruitBid:Fire(fruit.id)
    end)
    if ok and response then
        fruit.value = response.CurrentSellValue or response.CurrentOffer or response.BidPrice or 0
    end
end

local function promoteToTool(fruitId)
    local ok = pcall(function() Networking.Backpack.PromoteFruit:Fire(fruitId) end)
    if not ok then return nil end
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local startT = tick()
    while tick() - startT < 1.5 do
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") and item:GetAttribute("Id") == fruitId
                and not item:GetAttribute("FruitProxy") then return item end
        end
        task.wait(0.05)
    end
    return nil
end

local function equipFruit(fruit)
    local item = fruit.tool
    if not item or not item.Parent then return false end
    if not item:IsA("Tool") or item:GetAttribute("FruitProxy") then
        local newTool = promoteToTool(fruit.id)
        if not newTool then return false end
        item = newTool; fruit.tool = newTool; fruit.isProxy = false
    end
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    if item.Parent == char then item.Parent = LocalPlayer.Backpack; return true end
    hum:EquipTool(item)
    return true
end

local function dropFruit(fruit)
    local item = fruit.tool
    if not item or not item.Parent then return false end
    if not item:IsA("Tool") or item:GetAttribute("FruitProxy") then
        local newTool = promoteToTool(fruit.id)
        if not newTool then return false end
        item = newTool; fruit.tool = newTool; fruit.isProxy = false
    end
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t ~= item then t.Parent = LocalPlayer.Backpack end
    end
    if item.Parent ~= char then
        pcall(function() hum:EquipTool(item) end)
        task.wait(0.1)
    end
    VIM:SendKeyEvent(true, Enum.KeyCode.Backspace, false, game)
    task.wait(0.03)
    VIM:SendKeyEvent(false, Enum.KeyCode.Backspace, false, game)
    return true
end

local function countFloorFruits()
    local folder = Workspace:FindFirstChild("DroppedItems")
    if not folder then return 0 end
    local count = 0
    for _, c in ipairs(folder:GetChildren()) do
        if c:IsA("Model") and c.Name:sub(1,12) == "DroppedItem_" then count = count + 1 end
    end
    return count
end

local function waitForFloorSpace(cb, maxWait)
    maxWait = maxWait or 60
    local startT = tick()
    while true do
        local n = countFloorFruits()
        if n < FLOOR_LIMIT then return true, n end
        if cb then cb(n) end
        if tick() - startT > maxWait then return false, n end
        task.wait(0.5)
    end
end

local function parseValue(s)
    s = tostring(s):lower():gsub("[%s,_]", "")
    if s == "" then return 0 end
    local n, suf = s:match("^([%d%.]+)([kmbt]?)$")
    if not n then return tonumber(s) or 0 end
    n = tonumber(n) or 0
    local mults = {k=1e3,m=1e6,b=1e9,t=1e12}
    return n * (mults[suf] or 1)
end

local function selectFruitsForTarget(fruits, target)
    local pool = {}
    for _, f in ipairs(fruits) do
        if f.value > 0 then table.insert(pool, f) end
    end
    if #pool == 0 then return {}, 0 end
    table.sort(pool, function(a,b) return a.value < b.value end)
    local picked, pickedSet, total = {}, {}, 0
    for _, f in ipairs(pool) do
        if total + f.value <= target then
            table.insert(picked, f); pickedSet[f] = true; total = total + f.value
        end
    end
    if total < target then
        local best, bestNew = nil, math.huge
        for _, f in ipairs(pool) do
            if not pickedSet[f] then
                local nt = total + f.value
                if nt >= target and nt < bestNew then bestNew, best = nt, f end
            end
        end
        if best then
            table.insert(picked, best); pickedSet[best] = true; total = bestNew
        else
            for _, f in ipairs(pool) do
                if not pickedSet[f] then
                    table.insert(picked, f); total = total + f.value
                end
            end
        end
    end
    local improved = true
    while improved do
        improved = false
        for i = #picked, 1, -1 do
            local p = picked[i]
            if total - p.value >= target then
                total = total - p.value; pickedSet[p] = nil
                table.remove(picked, i); improved = true
            end
        end
    end
    improved = true
    while improved do
        improved = false
        for i, p in ipairs(picked) do
            for _, f in ipairs(pool) do
                if not pickedSet[f] then
                    local nt = total - p.value + f.value
                    if nt >= target and nt < total then
                        pickedSet[p] = nil; pickedSet[f] = true
                        picked[i] = f; total = nt; improved = true; break
                    end
                end
            end
            if improved then break end
        end
    end
    return picked, total
end

-- =================== AUTO-COLLECT ===================

local AC = {
    enabled = false, alive = true,
    collected = {}, failCount = {},
    stats = { total = 0, scans = 0, fires = 0 },
    homeCFrame = nil, addedConn = nil, removedConn = nil,
    SCAN_RATE = 2.0, PER_ITEM_GAP = 0.35, TP_SETTLE = 0.12,
    VERIFY_WAIT = 1.0, MAX_RETRIES = 2, HOVER_OFFSET = 3,
}

if _G.__AutoCollectFruit_Stop then pcall(_G.__AutoCollectFruit_Stop) end
_G.__AutoCollectFruit_Stop = function() AC.alive = false; AC.enabled = false end

local function ac_getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function ac_getModelPos(model)
    if model.PrimaryPart then return model.PrimaryPart.Position end
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("BasePart") then return d.Position end
    end
    local ok, cf = pcall(function() return model:GetPivot() end)
    if ok then return cf.Position end
end

local function ac_findPrompt(model)
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("ProximityPrompt") then return d end
    end
end

local function ac_describeFolder()
    local f = Workspace:FindFirstChild("DroppedItems")
    if not f then return "no DroppedItems folder" end
    local total, fruits, pending = 0, 0, 0
    for _, m in ipairs(f:GetChildren()) do
        total += 1
        if m:GetAttribute("ItemCategory") == "HarvestedFruits" then
            fruits += 1
            if not AC.collected[m] then pending += 1 end
        end
    end
    return string.format("floor=%d fruits=%d pending=%d", total, fruits, pending)
end

local function ac_collect(model)
    if not AC.alive or not AC.enabled then return end
    if AC.collected[model] then return end
    if not model.Parent then return end
    if model:GetAttribute("ItemCategory") ~= "HarvestedFruits" then return end

    local prompt = ac_findPrompt(model)
    if not prompt then return end
    local fruitPos = ac_getModelPos(model)
    if not fruitPos then return end
    local hrp = ac_getHRP()
    if not hrp then return end

    local savedHere = false
    if not AC.homeCFrame then
        AC.homeCFrame = hrp.CFrame
        savedHere = true
    end

    pcall(function()
        hrp.CFrame = CFrame.new(fruitPos + Vector3.new(0, AC.HOVER_OFFSET, 0))
    end)
    task.wait(AC.TP_SETTLE)

    pcall(function()
        prompt.MaxActivationDistance = 1000
        prompt.RequiresLineOfSight = false
        prompt.HoldDuration = 0
        prompt.Enabled = true
    end)

    pcall(function() fireproximityprompt(prompt) end)
    AC.stats.fires += 1

    task.wait(AC.VERIFY_WAIT)

    if not model.Parent then
        AC.collected[model] = true
        AC.failCount[model] = nil
    else
        AC.failCount[model] = (AC.failCount[model] or 0) + 1
        if AC.failCount[model] >= AC.MAX_RETRIES then
            AC.collected[model] = true
        end
    end

    if savedHere then
        local h = ac_getHRP()
        if h and AC.homeCFrame then pcall(function() h.CFrame = AC.homeCFrame end) end
        AC.homeCFrame = nil
    end
    task.wait(AC.PER_ITEM_GAP)
end

local function ac_scanAll()
    AC.stats.scans += 1
    local folder = Workspace:FindFirstChild("DroppedItems")
    if not folder then return end
    AC.homeCFrame = nil
    for _, m in ipairs(folder:GetChildren()) do
        if not AC.alive or not AC.enabled then break end
        if not AC.collected[m] and m:GetAttribute("ItemCategory") == "HarvestedFruits" then
            ac_collect(m)
        end
    end
    if AC.homeCFrame then
        local h = ac_getHRP()
        if h then pcall(function() h.CFrame = AC.homeCFrame end) end
        AC.homeCFrame = nil
    end
end

local function ac_start()
    local folder = Workspace:WaitForChild("DroppedItems", 10)
    if not folder then warn("[AC] DroppedItems missing"); return end
    if AC.addedConn then AC.addedConn:Disconnect() end
    if AC.removedConn then AC.removedConn:Disconnect() end
    AC.addedConn = folder.ChildAdded:Connect(function(m)
        task.wait(0.2); ac_collect(m)
    end)
    AC.removedConn = folder.ChildRemoved:Connect(function(m)
        if not AC.collected[m] then AC.stats.total += 1 end
        AC.collected[m] = nil; AC.failCount[m] = nil
    end)
    print("[AC] STARTED", ac_describeFolder())
    task.spawn(ac_scanAll)
end

local function ac_stop()
    if AC.addedConn then AC.addedConn:Disconnect(); AC.addedConn = nil end
    if AC.removedConn then AC.removedConn:Disconnect(); AC.removedConn = nil end
    table.clear(AC.collected); table.clear(AC.failCount)
    print("[AC] STOPPED")
end

task.spawn(function()
    while AC.alive do
        task.wait(AC.SCAN_RATE)
        if AC.enabled then ac_scanAll() end
    end
end)

